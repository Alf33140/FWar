{% extends 'base.html.twig' %}

{% block title %}RPG Hexagonal - Vue Perception{% endblock %}

{% block body %}
<style>
    body { margin: 0; background: #000; overflow: hidden; }
    canvas { display: block; }
    #ui { 
        position: fixed; 
        top: 20px; 
        left: 20px; 
        color: white; 
        background: rgba(0,0,0,0.8); 
        padding: 15px; 
        border-radius: 8px; 
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        pointer-events: none;
        border: 1px solid #444;
        box-shadow: 0 4px 15px rgba(0,0,0,0.5);
    }
    .controls { font-size: 0.8em; color: #aaa; margin-top: 10px; }
    .key { color: #fbc02d; font-weight: bold; }
</style>

<div id="ui">
    <strong>Système de Perception</strong><br>
    Position: <span id="pos-display">...</span><br>
    Perception: <span id="percept-display">...</span><br>
    <hr style="border: 0; border-top: 1px solid #444;">
    <small>Status: <span id="status">Initialisation...</span></small>
    <div class="controls">Déplacement: <span class="key">Flèches</span></div>
</div>

<canvas id="mapCanvas"></canvas>

<script>
const canvas = document.getElementById('mapCanvas');
const ctx = canvas.getContext('2d');

// --- 1. CHARGEMENT DES IMAGES ---
const terrainImages = {};
const terrains = ['plaine', 'colline', 'montagne', 'desert', 'sable', 'marecage', 'neige', 'steppe', 'eau', 'eau_profonde'];
let imagesLoaded = 0;

terrains.forEach(t => {
    terrainImages[t] = new Image();
    terrainImages[t].src = `/images/tiles/${t}.png`;
    terrainImages[t].onload = () => {
        imagesLoaded++;
        if (imagesLoaded === terrains.length) updateMap(); // Redessine quand tout est prêt
    };
});

// --- CONFIGURATION DU JOUEUR ---
let player = {
    q: 250, 
    r: 250,
    perception: 10 
};

const hexSize = 30; 
const hexHeight = Math.sqrt(3) * hexSize;
const colors = {
    'plaine': '#7cb342', 'colline': '#aed581', 'montagne': '#795548',
    'desert': '#fbc02d', 'sable': '#fff176', 'marecage': '#4db6ac',
    'neige': '#ffffff', 'steppe': '#d4e157', 'eau': '#4fc3f7',
    'eau_profonde': '#0288d1'
};

function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    updateMap();
}
window.addEventListener('resize', resize);
resize();

function drawHex(x, y, type, q, r) {
    const img = terrainImages[type];

    if (img && img.complete && img.naturalWidth !== 0) {
        // Dessin de l'image (légèrement agrandie pour éviter les interstices)
        ctx.drawImage(img, x - hexSize, y - hexSize, hexSize * 2.1, hexSize * 2.1);
    } else {
        // Fallback vectoriel
        ctx.beginPath();
        for (let i = 0; i < 6; i++) {
            let angle = (Math.PI / 3) * i;
            let px = x + hexSize * Math.cos(angle);
            let py = y + hexSize * Math.sin(angle);
            if (i === 0) ctx.moveTo(px, py);
            else ctx.lineTo(px, py);
        }
        ctx.closePath();
        ctx.fillStyle = colors[type] || '#333';
        ctx.fill();
        ctx.strokeStyle = 'rgba(255,255,255,0.1)';
        ctx.stroke();
    }

    // Coordonnées textuelles
    if (hexSize > 20) {
        ctx.fillStyle = "rgba(0,0,0,0.4)";
        ctx.font = "bold 10px Arial";
        ctx.textAlign = "center";
        ctx.fillText(`${q},${r}`, x, y + 5);
    }
}

function drawPlayer(x, y) {
    ctx.save();
    ctx.beginPath();
    ctx.arc(x, y, hexSize / 1.5, 0, Math.PI * 2);
    ctx.fillStyle = "white";
    ctx.shadowBlur = 20;
    ctx.shadowColor = "cyan";
    ctx.fill();
    ctx.lineWidth = 3;
    ctx.strokeStyle = "rgba(0, 255, 255, 0.8)";
    ctx.stroke();
    ctx.restore();
}

function updateMap() {
    const statusEl = document.getElementById('status');
    statusEl.innerText = "Chargement...";
    document.getElementById('pos-display').innerText = `${player.q}, ${player.r}`;
    document.getElementById('percept-display').innerText = player.perception;

    fetch(`/api/map/${player.q}/${player.r}/${player.perception}`)
        .then(response => response.json())
        .then(tiles => {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            const centerX = canvas.width / 2;
            const centerY = canvas.height / 2;

            tiles.forEach(tile => {
                const pixelX = centerX + (tile.q - player.q) * (hexSize * 1.5);
                const pixelY = centerY + (tile.r - player.r) * hexHeight + (tile.q % 2) * (hexHeight / 2) - (player.q % 2) * (hexHeight / 2);
                drawHex(pixelX, pixelY, tile.t, tile.q, tile.r);
            });

            drawPlayer(centerX, centerY);
            statusEl.innerText = "Prêt";
        })
        .catch(err => {
            statusEl.innerText = "Erreur API";
            console.error(err);
        });
}

// --- GESTION DES DÉPLACEMENTS ---
window.addEventListener('keydown', (e) => {
    switch(e.key) {
        case 'ArrowUp': player.r--; break;
        case 'ArrowDown': player.r++; break;
        case 'ArrowLeft': player.q--; break;
        case 'ArrowRight': player.q++; break;
        default: return;
    }
    updateMap();
});

updateMap();
</script>
{% endblock %}